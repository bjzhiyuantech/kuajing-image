# OpenAI image API configuration.
# Do not commit real API keys.
# Leave OPENAI_BASE_URL empty to use the official OpenAI API.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_TIMEOUT_MS=1200000

# Server/runtime.
PORT=8787
PUBLIC_PORT=8787
DEV_PUBLIC_PORT=8790
BLUE_PORT=8788
GREEN_PORT=8789
HOST=127.0.0.1
DATA_DIR=./data

# User authentication.
# PC and extension clients should call /api/auth/login or /api/auth/register,
# then send Authorization: Bearer <JWT>.
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Administrator

# SMTP email verification.
# You can also configure these in the admin panel; saved admin settings take precedence.
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=商图 AI 助手
SMTP_FROM_EMAIL=

# Aliyun SMS verification.
# You can also configure these in the admin panel; saved admin settings take precedence.
ALIYUN_SMS_ENABLED=false
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_REGISTER_TEMPLATE_CODE=
ALIYUN_SMS_BIND_TEMPLATE_CODE=

# Development-only fallback that re-enables the old demo x-user-id/x-workspace-id tenant.
# Keep false in shared/staging/production environments.
ALLOW_DEMO_AUTH=false

# MySQL storage.
# Use DATABASE_URL or the MYSQL_* fields below. Docker Compose defaults match these values.
DATABASE_URL=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=gpt_image_canvas
MYSQL_PASSWORD=gpt_image_canvas
MYSQL_DATABASE=gpt_image_canvas
MYSQL_ROOT_PASSWORD=root

# Optional cloud asset storage.
# The app stores generated images locally by default. Configure this from the in-app
# cloud storage settings dialog when you want generated images to be uploaded to OSS or COS.
# These defaults only prefill the cloud storage settings dialog; access keys are
# entered in the UI and stored locally in SQLite after a successful test upload.
# Secrets saved from the UI are stored in the local database and are never returned
# in full by the settings API.
OSS_DEFAULT_BUCKET=
OSS_DEFAULT_REGION=oss-cn-hangzhou
OSS_DEFAULT_KEY_PREFIX=gpt-image-canvas/assets
COS_DEFAULT_BUCKET=source-1253253332
COS_DEFAULT_REGION=ap-nanjing
COS_DEFAULT_KEY_PREFIX=gpt-image-canvas/assets
# Optional CDN base URL for generated assets uploaded to cloud storage.
# When set, API responses include asset.cdnUrl and, for OSS assets, thumbnail URLs
# using x-oss-process image resize parameters.
ASSET_CDN_BASE_URL=

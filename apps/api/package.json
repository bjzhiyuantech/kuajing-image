{
  "name": "@gpt-image-canvas/api",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "corepack pnpm --filter @gpt-image-canvas/shared build && tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "typecheck": "corepack pnpm --filter @gpt-image-canvas/shared build && tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@gpt-image-canvas/shared": "workspace:^",
    "@hono/node-server": "^2.0.0",
    "ali-oss": "^6.23.0",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "mysql2": "^3.22.3",
    "openai": "^6.34.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}

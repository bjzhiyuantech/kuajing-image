{
  "manifest_version": 3,
  "name": "跨境图片助手",
  "version": "0.1.1",
  "description": "在浏览器右侧边栏批量生成跨境电商商品图。",
  "action": {
    "default_title": "打开跨境图片助手"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": ["activeTab", "sidePanel", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1:8787/*", "http://localhost:8787/*", "https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-hook.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}

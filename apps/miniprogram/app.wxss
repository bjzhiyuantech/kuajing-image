page {
  background: #f6f8fb;
  color: #101828;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.section {
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 34rpx rgba(16, 24, 40, 0.04);
}

.title {
  font-size: 38rpx;
  font-weight: 800;
  color: #101828;
}

.subtitle {
  margin-top: 8rpx;
  color: #667085;
  line-height: 1.5;
}

.label {
  display: block;
  margin: 24rpx 0 10rpx;
  color: #475467;
  font-size: 26rpx;
  font-weight: 600;
}

.input,
.textarea,
.picker {
  width: 100%;
  min-height: 92rpx;
  box-sizing: border-box;
  border: 1rpx solid #d8dee8;
  border-radius: 18rpx;
  background: #fbfcfe;
  padding: 20rpx 22rpx;
}

.textarea {
  height: 150rpx;
}

.primary-button {
  margin-top: 30rpx;
  border-radius: 18rpx;
  background: #155eef;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 12rpx 28rpx rgba(21, 94, 239, 0.18);
}

.secondary-button {
  margin-top: 18rpx;
  border-radius: 18rpx;
  background: #edf3ff;
  color: #155eef;
  font-weight: 700;
}

.muted {
  color: #667085;
}

.danger {
  color: #d92d20;
}

.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pill {
  padding: 14rpx 20rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 999rpx;
  color: #344054;
  background: #ffffff;
}

.pill.active {
  border-color: #155eef;
  color: #155eef;
  background: #eef4ff;
}

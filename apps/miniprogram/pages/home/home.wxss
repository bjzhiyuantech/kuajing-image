.home-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 44rpx;
  box-sizing: border-box;
  background: #f6f8fb;
}

.home-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 2rpx 26rpx;
}

.brand-line {
  color: #155eef;
  font-size: 26rpx;
  font-weight: 800;
}

.hero-title {
  margin-top: 8rpx;
  color: #101828;
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 900;
}

.hero-copy {
  width: 540rpx;
  margin-top: 12rpx;
  color: #667085;
  font-size: 27rpx;
  line-height: 1.5;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #155eef;
  background: #eaf1ff;
  font-size: 28rpx;
  font-weight: 800;
}

.hero-card {
  position: relative;
  min-height: 384rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background: #101828;
  box-shadow: 0 24rpx 60rpx rgba(16, 24, 40, 0.16);
}

.hero-glow {
  position: absolute;
  right: -120rpx;
  top: -120rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: rgba(21, 94, 239, 0.45);
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 38rpx 34rpx;
}

.hero-kicker {
  color: #84adff;
  font-size: 20rpx;
  font-weight: 800;
}

.hero-heading {
  width: 470rpx;
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 900;
}

.hero-sub {
  width: 450rpx;
  margin-top: 16rpx;
  color: #c7d7fe;
  font-size: 25rpx;
  line-height: 1.5;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 26rpx;
}

.start-button {
  width: 210rpx;
  height: 74rpx;
  margin: 0;
  border-radius: 999rpx;
  background: #ffffff;
  color: #155eef;
  font-size: 27rpx;
  font-weight: 800;
}

.ghost-button {
  height: 74rpx;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 700;
}

.mock-stack {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  width: 220rpx;
  height: 250rpx;
}

.mock-card {
  position: absolute;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 20rpx 44rpx rgba(0, 0, 0, 0.16);
}

.mock-main {
  right: 0;
  bottom: 0;
  width: 188rpx;
  height: 224rpx;
  padding: 14rpx;
  box-sizing: border-box;
}

.mock-image {
  height: 126rpx;
  border-radius: 18rpx;
  background: linear-gradient(145deg, #dceafe, #fef7c3 55%, #fbcfe8);
}

.mock-line,
.mock-mini-line {
  height: 10rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: #d0d5dd;
}

.mock-line.wide {
  width: 120rpx;
}

.mock-line {
  width: 82rpx;
}

.mock-float {
  left: 0;
  top: 20rpx;
  width: 152rpx;
  height: 78rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx;
  box-sizing: border-box;
}

.spark {
  width: 34rpx;
  height: 34rpx;
  border-radius: 12rpx;
  background: #155eef;
}

.mock-mini-line {
  width: 74rpx;
  margin-top: 0;
}

.mock-mini-line.short {
  width: 48rpx;
  margin-top: 10rpx;
}

.section-block {
  margin-top: 34rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  color: #101828;
  font-size: 34rpx;
  font-weight: 850;
}

.section-more {
  color: #155eef;
  font-size: 26rpx;
  font-weight: 700;
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.feature-item {
  min-height: 204rpx;
  padding: 24rpx;
  border: 1rpx solid #edf0f5;
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(16, 24, 40, 0.05);
  box-sizing: border-box;
}

.feature-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  background: #155eef;
}

.feature-icon.translate {
  background: #079455;
}

.feature-icon.watermark {
  background: #dc6803;
}

.feature-icon.category {
  background: #7a5af8;
}

.feature-title {
  margin-top: 18rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 800;
}

.feature-desc {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.38;
}

.workflow-scroll {
  width: 100%;
  white-space: nowrap;
}

.workflow-card {
  display: inline-block;
  width: 520rpx;
  min-height: 250rpx;
  margin-right: 18rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid #edf0f5;
  box-shadow: 0 12rpx 34rpx rgba(16, 24, 40, 0.05);
  box-sizing: border-box;
  white-space: normal;
  vertical-align: top;
}

.workflow-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.workflow-badge {
  color: #155eef;
  background: #eaf1ff;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.workflow-count {
  color: #667085;
  font-size: 23rpx;
  font-weight: 700;
}

.workflow-title {
  margin-top: 22rpx;
  color: #101828;
  font-size: 32rpx;
  font-weight: 850;
}

.workflow-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.45;
}

.workflow-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.workflow-tags text {
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  color: #475467;
  background: #f2f4f7;
  font-size: 22rpx;
}

.recent-list {
  border-radius: 24rpx;
  background: #ffffff;
  overflow: hidden;
  border: 1rpx solid #edf0f5;
}

.recent-item {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid #f2f4f7;
}

.recent-title {
  color: #101828;
  font-size: 28rpx;
  font-weight: 750;
}

.recent-meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
}

.recent-status {
  flex: none;
  align-self: flex-start;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #344054;
  background: #f2f4f7;
  font-size: 22rpx;
  font-weight: 700;
}

.recent-status.succeeded {
  color: #027a48;
  background: #ecfdf3;
}

.recent-status.running,
.recent-status.pending {
  color: #175cd3;
  background: #eff8ff;
}

.recent-status.failed {
  color: #b42318;
  background: #fef3f2;
}

.empty-task {
  padding: 34rpx;
  border: 1rpx dashed #cfd8e5;
  border-radius: 26rpx;
  background: #ffffff;
}

.empty-title {
  color: #101828;
  font-size: 29rpx;
  font-weight: 800;
}

.empty-copy {
  margin-top: 8rpx;
  color: #667085;
  font-size: 25rpx;
}

.member-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  padding: 26rpx 28rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #155eef, #53389e);
  box-shadow: 0 20rpx 48rpx rgba(21, 94, 239, 0.18);
}

.member-title {
  font-size: 30rpx;
  font-weight: 850;
}

.member-copy {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
}

.member-arrow {
  font-size: 56rpx;
  line-height: 1;
}

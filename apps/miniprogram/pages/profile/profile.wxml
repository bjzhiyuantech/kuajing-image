<view class="page">
  <view class="section">
    <view class="title">我的会员</view>
    <view class="subtitle">同步使用后端账号、会员等级、额度和余额。</view>
    <button class="secondary-button" loading="{{loading}}" bindtap="loadProfile">刷新资料</button>
  </view>

  <view wx:if="{{user}}" class="section">
    <view class="profile-name">{{user.displayName}}</view>
    <view class="muted">{{user.email}}</view>
    <view class="profile-note" wx:if="{{!user.email}}">建议尽快补全邮箱，方便找回账号与接收通知。</view>
    <view class="field">
      <text class="field-label">昵称</text>
      <input class="login-input" value="{{displayNameDraft}}" bindinput="onDisplayNameInput" placeholder="昵称" />
    </view>
    <view class="field">
      <text class="field-label">邮箱</text>
      <input class="login-input" value="{{emailDraft}}" bindinput="onEmailInput" type="text" placeholder="邮箱" />
    </view>
    <button class="secondary-button" loading="{{savingProfile}}" bindtap="saveProfile">保存资料</button>
    <view class="metric-row">
      <view class="metric">
        <view class="metric-value">{{user.planName || user.planId || '免费版'}}</view>
        <view class="muted">会员等级</view>
      </view>
      <view class="metric">
        <view class="metric-value">{{remainingQuota}}</view>
        <view class="muted">剩余额度</view>
      </view>
    </view>
    <view class="metric-row">
      <view class="metric">
        <view class="metric-value">{{user.quotaUsed || 0}}</view>
        <view class="muted">已用图片</view>
      </view>
      <view class="metric">
        <view class="metric-value">{{balance}}</view>
        <view class="muted">账户余额</view>
      </view>
    </view>
    <button class="secondary-button danger" bindtap="logout">退出登录</button>
  </view>

  <view wx:else class="section">
    <view class="muted">当前未登录。</view>
    <button class="primary-button" bindtap="goLogin">去登录</button>
  </view>
</view>
